lib_component_ui_menu_control_power_saving = [*
ui_menu_control_power_saving <- ui_user_command_class_atom; ui_user_command_class_view_kb; ui_two_arguments_command_class;;

ui_menu_control_power_saving
=> nrel_main_idtf:
    [Проверить энергосбережение дома]
    (* <- lang_ru;; *);
    [Check home power saving]
    (* <- lang_en;; *);;

ui_menu_control_power_saving => ui_nrel_command_template:
    [*
        action_control_power_saving _-> ._action_control_power_saving_instance
            (*
                _-> rrel_1:: ui_arg_1;;
                _-> rrel_2:: ui_arg_2;;
            *);;
        ._action_control_power_saving_instance <-_ action;;
    *];;

ui_menu_control_power_saving => ui_nrel_command_lang_template: [Проверить энергосбережение дома $ui_arg_1 по событию $ui_arg_2] (* <- lang_ru;; *);;
ui_menu_control_power_saving => ui_nrel_command_lang_template: [Check home power saving $ui_arg_1 by event $ui_arg_2] (* <- lang_en;; *);;
*];;
